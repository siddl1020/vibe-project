NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# 회원가입 이메일 확인 리다이렉트 (서버 전용 권장). 미설정 시 개발에서는 localhost:3000 사용.
# 프로덕션에서는 반드시 실제 사이트 origin (예: https://app.example.com)
APP_URL=http://localhost:3000

# 이메일 확인 사용 시: Supabase → Authentication → URL Configuration
# → Redirect URLs 에 APP_URL과 동일한 origin의 /auth/callback 추가

# (선택) 호스팅 프로젝트에서 mailer_autoconfirm 켜기: npm run auth:enable-email-autoconfirm
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=your_project_ref
